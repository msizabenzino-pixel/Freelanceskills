{
  "expo": {
    "name": "FreelanceSkills",
    "slug": "freelance-skills",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "freelanceskills",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.freelanceskills.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "package": "net.freelanceskills.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FreelanceSkills to access your camera for ID verification and portfolio photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow FreelanceSkills to use your location to find nearby jobs."
        }
      ],
      "expo-local-authentication",
      "expo-calendar",
      [
        "@sentry/react-native",
        {
          "organization": "freelanceskills",
          "project": "mobile-app"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
