# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  FreelanceSkills.net — Environment Variables                             ║
# ║  Copy this file to .env and fill in your values                         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
SITE_URL=https://freelanceskills.net

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/freelanceskills

# ── Session Security ──────────────────────────────────────────────────────────
SESSION_SECRET=your-very-long-random-session-secret-at-least-64-chars

# ── AI (Replit Managed — OpenAI via AI Integrations) ─────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Anthropic Claude (Section 30 AI Brain fallback)
ANTHROPIC_API_KEY=

# ── Payments ──────────────────────────────────────────────────────────────────
# PayFast (South Africa)
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_SANDBOX=false

# PayPal (Global)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ── Push Notifications (Web Push / PWA) ──────────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Analytics ─────────────────────────────────────────────────────────────────
GA_TRACKING_ID=G-XXXXXXXXXX

# ── Replit Platform ───────────────────────────────────────────────────────────
REPLIT_DOMAINS=your-repl-domain.replit.dev

# ── Optional: SMS / WhatsApp (Africa First) ───────────────────────────────────
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Optional: Email ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@freelanceskills.net

# ── Optional: Storage ─────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION LAUNCH CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════
# [ ] DATABASE_URL points to production PostgreSQL
# [ ] SESSION_SECRET is 64+ random characters (not default)
# [ ] NODE_ENV=production
# [ ] PAYFAST_SANDBOX=false (turn off test mode)
# [ ] All AI keys set (AI Brain + Mission Control AI require OpenAI)
# [ ] SITE_URL is your production domain (for CORS + PayFast ITN)
# [ ] VAPID keys generated (npx web-push generate-vapid-keys)
# [ ] GA_TRACKING_ID set for analytics
# [ ] Run: npx tsx script/build.ts && NODE_ENV=production node dist/index.cjs
